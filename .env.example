# ─────────────────────────────────────────────────────────────
# RubberForm Traffic Intelligence — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Google Search Console ──────────────────────────────────────
# Must exactly match the property URL in Search Console
# Check: https://search.google.com/search-console → property selector
GSC_SITE_URL=https://www.rubberform.com/

# ── Google Analytics 4 ────────────────────────────────────────
# Found in GA4 → Admin → Property Settings (top right corner)
# Looks like: 123456789  (NOT "G-XXXXXXX" — that's the measurement ID)
GA4_PROPERTY_ID=

# Paste the ENTIRE contents of your service-account JSON key file here
# (all on one line or with escaped newlines — Railway handles multi-line fine).
# Create via: GCP Console → IAM & Admin → Service Accounts → Keys → Add JSON.
# Grant the service account "Viewer" access to your GA4 property at
# GA4 → Admin → Property access management.
GOOGLE_CREDENTIALS_JSON=

# ── NetSuite TBA Credentials ──────────────────────────────────
# Setup: NetSuite → Setup → Integration → Manage Integrations → New
# Then: Setup → Users/Roles → User Token Management → New Token
# Account ID is in your NS URL: https://XXXXXXX.app.netsuite.com
NS_ACCOUNT_ID=3936233
NS_CONSUMER_KEY=
NS_CONSUMER_SECRET=
NS_TOKEN_ID=
NS_TOKEN_SECRET=

# ── Data Settings ─────────────────────────────────────────────
# How many days back to fetch (default 540 = ~18 months)
LOOKBACK_DAYS=540

# ── AI Analysis (optional) ────────────────────────────────────
# Enables the "✨ AI Analysis" button on both dashboard tabs.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────────────────────
PORT=3737
VITE_API_URL=http://localhost:3737

# IANA timezone for the nightly cron refresh. Defaults to America/New_York.
CRON_TIMEZONE=America/New_York
