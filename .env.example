# ─────────────────────────────────────────────────────────────
# RubberForm Traffic Intelligence — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Google Search Console ──────────────────────────────────────
# Must exactly match the property URL in Search Console
# Check: https://search.google.com/search-console → property selector
GSC_SITE_URL=https://www.rubberform.com/

# Branded vs non-branded query split. Default matches "rubberform" plus
# common spacing/hyphen variants. Override to add legacy product names,
# common misspellings, or brand variants. Case-insensitive.
# BRAND_QUERY_REGEX=rubberform|rubber-form|legacy-name|common-misspelling

# ── Chrome User Experience Report (Core Web Vitals) ────────────
# CrUX is the public real-user-monitoring dataset Google uses for ranking.
# Key from: https://console.cloud.google.com/apis/api/chromeuxreport.googleapis.com
# Enable the API on the same project as GA4. The origin used is GSC_SITE_URL.
# CRUX_API_KEY=

# ── Google Analytics 4 ────────────────────────────────────────
# Found in GA4 → Admin → Property Settings (top right corner)
# Looks like: 123456789  (NOT "G-XXXXXXX" — that's the measurement ID)
GA4_PROPERTY_ID=

# Paste the ENTIRE contents of your service-account JSON key file here
# (all on one line or with escaped newlines — Railway handles multi-line fine).
# Create via: GCP Console → IAM & Admin → Service Accounts → Keys → Add JSON.
# Grant the service account "Viewer" access to your GA4 property at
# GA4 → Admin → Property access management.
GOOGLE_CREDENTIALS_JSON=

# ── Google Ads (direct API, for Paid KPIs tab) ────────────────
# Powers cost / clicks / impressions / CPA / ROAS on the Paid KPIs tab.
# Setup:
#   1. Developer token: Ads Manager account → ads.google.com/aw/apicenter
#      Request "basic access" — approval takes hours, not days.
#   2. OAuth client (Desktop app):  GCP Console → APIs & Services → Credentials
#   3. Run a one-time consent flow to produce the refresh token (the README
#      has a one-shot script you can use).
#   4. Customer ID: the 10-digit account id, NO dashes.
#      Login-customer-id: only if the account sits under a Manager (MCC).
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── HubSpot (CRM deals + attribution) ─────────────────────────
# Used for the CPA denominator (real closed-won deals) and paid-vs-organic
# attribution on the Paid + SEO KPI tabs.
# Create at: HubSpot → Settings → Integrations → Private Apps → Create
# Required scopes:
#   crm.objects.deals.read
#   crm.schemas.deals.read
# Optional (Marketing Hub tiers, for campaign attribution):
#   crm.objects.marketing_events.read
HUBSPOT_PRIVATE_APP_TOKEN=

# ── NetSuite TBA Credentials ──────────────────────────────────
# Setup: NetSuite → Setup → Integration → Manage Integrations → New
# Then: Setup → Users/Roles → User Token Management → New Token
# Account ID is in your NS URL: https://XXXXXXX.app.netsuite.com
NS_ACCOUNT_ID=3936233
NS_CONSUMER_KEY=
NS_CONSUMER_SECRET=
NS_TOKEN_ID=
NS_TOKEN_SECRET=

# ── Data Settings ─────────────────────────────────────────────
# How many days back to fetch (default 540 = ~18 months)
LOOKBACK_DAYS=540

# Pagination safety caps. Fetchers now throw instead of silently truncating
# when they exceed these, so raise them if your account has more history than
# the default window. Header = one row per transaction, dim = one per line.
# NS_MAX_ROWS=200000
# NS_DIM_MAX_ROWS=500000

# ── AI Analysis (optional) ────────────────────────────────────
# Enables the "✨ AI Analysis" button on both dashboard tabs.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────────────────────
PORT=3737
VITE_API_URL=http://localhost:3737

# IANA timezone for the nightly cron refresh. Defaults to America/New_York.
CRON_TIMEZONE=America/New_York
